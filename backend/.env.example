# backend/.env.example
# Copia este archivo como .env y rellena los valores para tu entorno local.

DATABASE_URL=postgresql://USUARIO:CONTRASEÑA@localhost:5432/atlas_infancias
SECRET_KEY=CAMBIA_ESTO

# URL del frontend (usada para generar el link de recuperación de contraseña)
FRONTEND_URL=http://localhost:5173

# Configuración de correo (SMTP)
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_FROM=tu_correo@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False